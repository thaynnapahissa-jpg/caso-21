<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>CASO Nº 21</title>

<style>

body{
    margin:0;
    background:#0d0d0d;
    color:white;
    font-family:Arial, Helvetica, sans-serif;

    display:flex;
    justify-content:center;
    align-items:center;

    height:100vh;
}

.caixa{

    width:420px;

    background:#151515;

    border:2px solid gold;

    border-radius:15px;

    padding:40px;

    text-align:center;

    box-shadow:0 0 30px rgba(255,215,0,.15);

}

h1{

    color:gold;
    margin-bottom:5px;

}

h3{

    color:#cfcfcf;
    font-weight:normal;

    margin-bottom:35px;

}

input{

    width:90%;

    padding:14px;

    margin:10px;

    background:#222;

    border:none;

    color:white;

    border-radius:8px;

    font-size:16px;

}

button{

    width:95%;

    padding:15px;

    margin-top:25px;

    background:gold;

    color:black;

    border:none;

    border-radius:8px;

    font-size:18px;

    cursor:pointer;

    font-weight:bold;

}

button:hover{

    background:#ffd700;

}

#mensagem{

    margin-top:20px;

    color:#ff5a5a;

}

</style>

</head>

<body>

<div class="caixa">

<h1>CASO Nº 21</h1>

<h3>AGÊNCIA NACIONAL DE INVESTIGAÇÕES</h3>

<input
id="usuario"
placeholder="Usuário">

<input
id="senha"
type="password"
placeholder="Senha">

<button onclick="entrar()">

ACESSAR SISTEMA

</button>

<p id="mensagem"></p>

</div>

<script>

function entrar(){

let usuario=document.getElementById("usuario").value;

let senha=document.getElementById("senha").value;

if(usuario=="AGENTE021" && senha=="2106"){

document.body.innerHTML=`

<div style="display:flex;justify-content:center;align-items:center;height:100vh;background:black;color:lime;font-family:monospace;font-size:30px;">

ACESSO AUTORIZADO...

</div>

`;

}else{

document.getElementById("mensagem").innerHTML="Credenciais incorretas.";

}

}

</script>

</body>

</html>
